{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ItzamBox",
  "version": "1.3.0",
  "identifier": "com.sodigtech.itzambox",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "bash scripts/fix-linuxdeploy.sh && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "ItzamBox",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["docker-ce", "docker-ce-cli"]
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": ["https://github.com/JSilvaDev27/itzam-box/releases/latest/download/latest.json"],
      "pubkey": "PLACEHOLDER — generate with `cargo tauri signer generate`"
    }
  }
}
