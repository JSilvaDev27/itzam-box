# ═══════════════════════════════════════════
# ItzamBox — Environment Variables
# Copy this file to .env and fill in values.
# ═══════════════════════════════════════════

# Sentry DSN (Data Source Name) for error tracking
# Get yours at: https://sentry.io/settings/<org>/projects/<project>/keys/
# Leave empty to disable Sentry in development.
VITE_SENTRY_DSN=

# Application version used for Sentry releases
VITE_APP_VERSION=1.1.0
